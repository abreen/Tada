{
  "type": "object",
  "required": ["base", "title", "defaultTimeZone"],
  "properties": {
    "features": {
      "type": "object",
      "default": { "search": true, "code": true },
      "properties": {
        "search": { "type": "boolean", "default": true },
        "code": { "type": "boolean", "default": true },
        "favicon": { "type": "boolean", "default": false }
      },
      "required": ["search", "code", "favicon"],
      "additionalProperties": false
    },
    "base": { "type": "string", "pattern": "^https?:\\/\\/[-.:a-zA-Z0-9]+$" },
    "basePath": {
      "type": "string",
      "default": "/",
      "pattern": "^\\/[-a-zA-Z0-9]*?$"
    },
    "internalDomains": {
      "type": "array",
      "default": [],
      "items": { "type": "string", "pattern": "^[-.:a-zA-Z0-9]+$" }
    },
    "title": { "type": "string" },
    "symbol": { "type": "string", "pattern": "^[A-Z0-9\\- ]{1,5}$" },
    "titlePostfix": { "type": "string" },
    "themeColor": { "type": "string" },
    "tintHue": {
      "type": "integer",
      "minimum": 0,
      "maximum": 360,
      "default": 20
    },
    "tintAmount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 100
    },
    "faviconColor": { "type": "string" },
    "faviconSymbol": { "type": "string", "pattern": "^[A-Z0-9\\- ]{1,5}$" },
    "faviconFontWeight": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "default": 700
    },
    "defaultTimeZone": { "type": "string" },
    "vars": { "type": "object" },
    "codeLanguages": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
