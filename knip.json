{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "build/pipeline.ts",
    "build/serve.ts",
    "build/watch/index.ts",
    "build/watch-reload-client.ts",
    "src/index.ts",
    "src/critical.scss",
    "scripts/*.ts",
    "playwright.coverage.config.ts",
    "playwright/*.spec.ts",
    "playwright/serve-test-site.ts",
    "build/**/*.test.ts",
    "src/**/*.test.ts",
    "bin/**/*.test.ts",
    "templates/**/*.test.ts",
    "unit-test-preload.ts",
    "test-helpers.ts",
    "templates/_theme.scss"
  ],
  "project": [
    "*.ts",
    "*.config.{js,ts,mjs}",
    "bin/**/*.ts",
    "build/**/*.ts",
    "playwright/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.{ts,scss}",
    "templates/**/*.{ts,scss}",
    "types/**/*.d.ts"
  ],
  "tags": ["-lintignore"]
}
