{
  "name": "@abreen/tada",
  "version": "1.5.7",
  "type": "module",
  "description": "A static site generator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abreen/Tada.git"
  },
  "author": "Alex Breen <npm@abreen.email>",
  "bin": {
    "tada": "bin/tada.ts"
  },
  "files": [
    "bin/",
    "build/",
    "src/",
    "templates/",
    "fonts/",
    "init/",
    "schema/",
    "types/",
    "tsconfig.json",
    "!**/*.test.ts"
  ],
  "scripts": {
    "prepare": "bunx husky && bun run scripts/check-deps.ts",
    "prepack": "bun run scripts/prepack.ts",
    "lint": "eslint src/ build/ bin/",
    "typecheck": "tsc --noEmit",
    "test:functional": "python3 -m pip install -q -r functional_tests/requirements.txt && python3 -m pytest functional_tests/ -v -n auto --durations=10",
    "test:all": "bun test && bun run test:playwright && bun run test:functional",
    "test:coverage": "rm -rf coverage/unit coverage/functional && bun test --coverage && TADA_COVERAGE=1 python3 -m pip install -q -r functional_tests/requirements.txt && TADA_COVERAGE=1 python3 -m pytest functional_tests/ -v -n auto --durations=10 && bun run scripts/coverage-report.ts",
    "test:playwright": "bunx playwright test",
    "init-example": "bun run bin/tada.ts init example --no-interactive",
    "iew": "if [ -d example ]; then cd example; else bun run init-example && cd example; fi && ../bin/tada.ts watch"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "@vscode/markdown-it-katex": "^1.1.2",
    "ajv": "^8.17.1",
    "chokidar": "^4.0.0",
    "culori": "^4.0.2",
    "d3-flextree": "^2.1.2",
    "d3-hierarchy": "^3.1.2",
    "fontkit": "^2.0.4",
    "front-matter": "^4.0.2",
    "java-parser": "^3.0.1",
    "jsdom": "^26.1.0",
    "katex": "^0.16.40",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "pagefind": "^1.4.0",
    "png-to-ico": "^3.0.1",
    "quote-quote": "^1.2.0",
    "sass": "^1.91.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.1",
    "string-strip-html": "^8.5.0",
    "ws": "^8.18.0"
  },
  "lint-staged": {
    "*.{ts,js}": "prettier --write",
    "*.scss": "prettier --write",
    "*.json": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@saintedlama/lcov-parse": "^1.0.1",
    "@types/bun": "^1.3.10",
    "@types/culori": "^4.0.1",
    "@types/d3-flextree": "^2.1.4",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/fontkit": "^2.0.8",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-instrument": "^1.7.8",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it-container": "^4.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-instrument": "^6.0.3",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-curly": "^0.4.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.1"
  }
}
