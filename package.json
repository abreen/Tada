{
  "name": "@abreen/tada",
  "version": "1.10.1",
  "type": "module",
  "description": "A static site generator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abreen/Tada.git"
  },
  "author": "Alex Breen <npm@abreen.email>",
  "bin": {
    "tada": "bin/tada.ts"
  },
  "files": [
    "bin/",
    "build/",
    "watch/",
    "src/",
    "templates/",
    "fonts/",
    "init/",
    "schema/",
    "types/",
    "python/",
    "tsconfig.json",
    "!**/*.test.ts",
    "!**/__pycache__",
    "!**/__pycache__/**",
    "!**/*.pyc"
  ],
  "scripts": {
    "prepare": "bunx husky",
    "check-deps": "bun run scripts/check-deps.ts",
    "init-example": "bun run bin/tada.ts init example --no-interactive",
    "iew": "bun run scripts/init-example-watch.ts",
    "lint": "eslint src/ build/ bin/",
    "lint:sass": "bun run scripts/lint-sass.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,js,scss,json}\"",
    "test:playwright": "bun run scripts/test.ts playwright",
    "test:functional": "bun run scripts/test.ts functional",
    "test:all": "bun run scripts/test.ts all",
    "test:coverage": "bun run scripts/test.ts coverage",
    "setup:python": "bun run scripts/setup-python.ts",
    "lint:python": "bun run scripts/python-module.ts ruff check functional_tests/",
    "fix:python": "bun run scripts/python-module.ts ruff check --fix functional_tests/",
    "format:python": "bun run fix:python && bun run scripts/python-module.ts ruff format functional_tests/"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "dependencies": {
    "@vscode/markdown-it-katex": "^1.1.2",
    "ajv": "^8.18.0",
    "chokidar": "^4.0.3",
    "culori": "^4.0.2",
    "d3-flextree": "^2.1.2",
    "d3-hierarchy": "^3.1.2",
    "fontkit": "^2.0.4",
    "front-matter": "^4.0.2",
    "java-parser": "^3.0.1",
    "jsdom": "^26.1.0",
    "katex": "^0.16.45",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "pagefind": "^1.5.2",
    "png-to-ico": "^3.0.1",
    "quote-quote": "^1.2.0",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "string-strip-html": "^8.5.0",
    "ws": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,js}": "prettier --write",
    "src/**/*.scss": [
      "stylelint --fix --config stylelint.config.mjs",
      "prettier --write"
    ],
    "templates/**/*.scss": "prettier --write",
    "*.json": "prettier --write",
    "functional_tests/**/*.py": [
      "bun run scripts/python-module.ts ruff check --fix",
      "bun run scripts/python-module.ts ruff format"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@saintedlama/lcov-parse": "^1.0.1",
    "@types/bun": "^1.3.12",
    "@types/culori": "^4.0.1",
    "@types/d3-flextree": "^2.1.4",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/fontkit": "^2.0.9",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-instrument": "^1.7.8",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it-container": "^4.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-instrument": "^6.0.3",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "lint-staged": "^16.4.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.3",
    "prettier-plugin-curly": "^0.4.1",
    "stylelint": "^17.8.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
