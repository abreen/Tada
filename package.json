{
  "name": "@abreen/tada",
  "version": "1.1.0",
  "type": "module",
  "description": "A static site generator",
  "license": "MIT",
  "bin": {
    "tada": "bin/tada.ts"
  },
  "files": [
    "bin/",
    "build/",
    "src/",
    "templates/",
    "fonts/",
    "config/",
    "content/",
    "public/",
    "types/",
    "tsconfig.json"
  ],
  "scripts": {
    "prepare": "husky && bun run scripts/check-deps.ts",
    "init-example": "bun run bin/tada.ts init example --default",
    "lint": "eslint src/ build/ bin/",
    "typecheck": "tsc --noEmit",
    "test:functional": "python3 -m pip install -q -r functional_tests/requirements.txt && python3 -m pytest functional_tests/ -v -n auto --durations=10"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@tsconfig/node23": "^23.0.2",
    "ajv": "^8.17.1",
    "chokidar": "^4.0.0",
    "culori": "^4.0.2",
    "fontkit": "^2.0.4",
    "front-matter": "^4.0.2",
    "java-parser": "^3.0.1",
    "jsdom": "^26.1.0",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "pagefind": "^1.4.0",
    "png-to-ico": "^3.0.1",
    "quote-quote": "^1.2.0",
    "sass": "^1.91.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.1",
    "string-strip-html": "^8.5.0",
    "ws": "^8.18.0"
  },
  "lint-staged": {
    "*.{ts,js}": "prettier --write",
    "*.scss": "prettier --write",
    "*.json": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.43.0",
    "@types/bun": "^1.3.10",
    "@types/culori": "^4.0.1",
    "@types/fontkit": "^2.0.8",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it-container": "^4.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-curly": "^0.4.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.1"
  }
}
