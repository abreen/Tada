{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "dom", "dom.iterable"],
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "outDir": "./dist/",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true
  },
  "include": ["src", "types", "build", "bin"],
  "exclude": ["node_modules"]
}
